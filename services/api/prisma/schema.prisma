generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  passwordHash          String    @map("password_hash")
  role                  String    @default("user")
  educationLevel        String?   @map("education_level")
  displayName           String?   @map("display_name")
  fullName              String?   @map("full_name")
  phoneNumber           String?   @map("phone_number")
  banned                Boolean   @default(false)
  banReason             String?   @map("ban_reason")
  bannedDate            DateTime? @map("banned_date")
  bannedBy              String?   @map("banned_by")
  demographicsCollected Boolean   @default(false) @map("demographics_collected")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  sessions             Session[]
  subscriptions        Subscription[]
  auditLogs            AuditLog[]
  learningSessions     LearningSession[]
  learningProgress     LearningProgress[]
  searchHistory        SearchHistory[]
  userActivities       UserActivity[]
  medicalData          MedicalData[]
  aiConversations      AIConversation[]
  geneSets             GeneSet[]
  researchProjects     ResearchProject[]
  collaborations       ProjectCollaborator[]
  sentMessages         Message[]           @relation("sender")
  receivedMessages     Message[]           @relation("receiver")
  annotations          ProjectAnnotation[]
  consentRecords       ConsentRecord[]
  deletionRequests     DataDeletionRequest[]

  @@map("users")
}

model Session {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  refreshTokenHash String   @map("refresh_token_hash")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("sessions")
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  status               String
  planType             String    @map("plan_type")
  currentPeriodEnd     DateTime? @map("current_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@map("subscriptions")
}

model InstitutionalLicense {
  id                   String   @id @default(uuid())
  organizationName     String   @map("organization_name")
  contactEmail         String   @map("contact_email")
  licenseType          String   @map("license_type")
  maxSeats             Int      @map("max_seats")
  assignedSeats        Int      @default(0) @map("assigned_seats")
  status               String
  startDate            DateTime @map("start_date")
  endDate              DateTime @map("end_date")
  renewalDate          DateTime @map("renewal_date")
  autoRenew            Boolean  @default(false) @map("auto_renew")
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  pricing              Json
  adminUsers           String[] @map("admin_users")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  
  assignments LicenseAssignment[]
  usageLogs   LicenseUsageLog[]
  
  @@map("institutional_licenses")
}

model LicenseAssignment {
  id             String   @id @default(uuid())
  licenseId      String   @map("license_id")
  userEmail      String   @map("user_email")
  assignedBy     String   @map("assigned_by")
  status         String
  invitationSent Boolean  @default(false) @map("invitation_sent")
  department     String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  license InstitutionalLicense @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  
  @@index([userEmail, status])
  @@index([licenseId])
  @@map("license_assignments")
}

model LicenseUsageLog {
  id        String   @id @default(uuid())
  licenseId String   @map("license_id")
  userEmail String   @map("user_email")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  
  license InstitutionalLicense @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  
  @@map("license_usage_logs")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId, createdAt])
  @@map("audit_log")
}

model StripeEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique @map("stripe_event_id")
  type          String
  receivedAt    DateTime @default(now()) @map("received_at")
  
  @@map("stripe_events")
}

model LearningSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  topic     String
  level     String
  type      String
  content   Json?
  createdAt DateTime @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, type, createdAt])
  @@map("learning_sessions")
}

model LearningProgress {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  topicId        String   @map("topic_id")
  bestScore      Int      @default(0) @map("best_score")
  totalQuestions  Int      @default(0) @map("total_questions")
  attempts       Int      @default(0)
  lastAttemptAt  DateTime @default(now()) @map("last_attempt_at")
  createdAt      DateTime @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, topicId])
  @@index([userId])
  @@map("learning_progress")
}

model SearchHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  query     String
  queryType String   @map("query_type")
  results   Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("search_history")
}

model UserActivity {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  activityType String   @map("activity_type")
  entityType   String?  @map("entity_type")
  entityId     String?  @map("entity_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_activities")
}

model MedicalData {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  dataType    String   @map("data_type")
  title       String?
  content     Json
  fileUrl     String?  @map("file_url")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dataType])
  @@map("medical_data")
}

model AIConversation {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  assistantType String   @map("assistant_type")
  title         String?
  messages      Json
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, assistantType])
  @@map("ai_conversations")
}

model GeneSet {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  genes       String[]
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("gene_sets")
}

model ResearchProject {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  description String?
  status      String   @default("active")
  genes       String[]
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions      ProjectVersion[]
  collaborators ProjectCollaborator[]
  annotations   ProjectAnnotation[]

  @@index([userId])
  @@map("research_projects")
}

model ProjectVersion {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  version   Int
  changes   Json
  notes     String?
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_versions")
}

model ProjectCollaborator {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("viewer")
  addedBy   String   @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_collaborators")
}

model Message {
  id         String    @id @default(uuid())
  senderId   String    @map("sender_id")
  receiverId String?   @map("receiver_id")
  subject    String
  body       String
  category   String    @default("general")
  status     String    @default("open")
  parentId   String?   @map("parent_id")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  sender   User  @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User? @relation("receiver", fields: [receiverId], references: [id], onDelete: SetNull)

  @@index([senderId])
  @@index([receiverId, status])
  @@map("messages")
}

model PreBannedUser {
  id          String   @id @default(uuid())
  email       String?
  phoneNumber String?  @map("phone_number")
  fullName    String?  @map("full_name")
  reason      String?
  status      String   @default("active")
  bannedBy    String   @map("banned_by")
  triggeredAt DateTime? @map("triggered_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("pre_banned_users")
}

model ProjectAnnotation {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  userId      String   @map("user_id")
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  content     String
  parentId    String?  @map("parent_id")
  resolved    Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, targetType, targetId])
  @@map("project_annotations")
}

model ConsentRecord {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  consentType String   @map("consent_type")
  version     String
  granted     Boolean
  ipAddress   String?  @map("ip_address")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
  @@map("consent_records")
}

model DataDeletionRequest {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  status       String    @default("pending")
  requestedAt  DateTime  @default(now()) @map("requested_at")
  completedAt  DateTime? @map("completed_at")
  deletedTypes String[]  @map("deleted_types")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("data_deletion_requests")
}
