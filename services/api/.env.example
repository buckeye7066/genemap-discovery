# ─── Required in production (loadEnv() will refuse to start without these) ────
DATABASE_URL="postgresql://user:password@localhost:5432/genemap"
# Each of the three secrets below MUST be at least 32 characters of
# random data in production. Generate with:  openssl rand -base64 48
JWT_SECRET="REPLACE_WITH_32_PLUS_CHAR_RANDOM_STRING"
JWT_REFRESH_SECRET="REPLACE_WITH_32_PLUS_CHAR_RANDOM_STRING"
COOKIE_SECRET="REPLACE_WITH_32_PLUS_CHAR_RANDOM_STRING"
CORS_ORIGINS="http://localhost:5173,https://yourdomain.com"

# ─── Sensitive data encryption ────────────────────────────────────────────────
# 32-byte (64 hex chars) AES-256-GCM key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Production REFUSES to write or read medical data without this set.
MEDICAL_DATA_ENCRYPTION_KEY="REPLACE_WITH_64_HEX_CHARS"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_your_stripe_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PRICE_MONTHLY="price_monthly_id"
STRIPE_PRICE_YEARLY="price_yearly_id"
STRIPE_PRICE_TEAM_MONTHLY="price_team_monthly_id"
STRIPE_PRICE_TEAM_YEARLY="price_team_yearly_id"
STRIPE_PRICE_DEPT_MONTHLY="price_dept_monthly_id"
STRIPE_PRICE_DEPT_YEARLY="price_dept_yearly_id"
STRIPE_PRICE_ENT_MONTHLY="price_ent_monthly_id"
STRIPE_PRICE_ENT_YEARLY="price_ent_yearly_id"

# ─── LLM providers (at least one is required in production unless
# SKIP_LLM_KEY_CHECK=1, which fully disables LLM-backed routes) ───────────────
OPENAI_API_KEY="sk-your-openai-api-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
LLM_TEXT_PROVIDER="openai"
LLM_IMAGE_PROVIDER="openai"
LLM_TIMEOUT_MS="30000"
# SKIP_LLM_KEY_CHECK="1"  # uncomment to allow boot with no LLM provider

# ─── Misc ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS="ops@example.com"
NODE_ENV="development"
PORT=3000
HOST="0.0.0.0"
LOG_LEVEL="info"
# CSRF_SECRET="optional; double-submit cookie does not strictly need it"

