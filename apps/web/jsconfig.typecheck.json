{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "noResolve": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "types": []
  },
  "include": [
    "lib/**/*.js",
    "lib/**/*.ts",
    "lib/**/*.d.ts",
    "components/icons/**/*.js",
    "components/icons/**/*.jsx",
    "components/shared/**/*.js",
    "components/shared/**/*.jsx",
    "components/MobileOptimization.jsx",
    "components/PlatformCompatibility.jsx",
    "components/UniversalLinkHandler.jsx",
    "components/UserNotRegisteredError.jsx",
    "components/functionRegistry.js"
  ],
  "exclude": ["node_modules", "dist", "public/service-worker.js"]
}
