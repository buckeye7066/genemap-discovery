{
  "name": "genemap-discovery",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/* dev",
    "dev:api": "pnpm --filter @genemap/api dev",
    "dev:web": "pnpm --filter @genemap/web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @genemap/api build",
    "build:web": "pnpm --filter @genemap/web build",
    "dev:desktop": "pnpm --filter @genemap/desktop dev",
    "build:desktop": "pnpm build:web && pnpm --filter @genemap/desktop build",
    "build:desktop:win": "pnpm build:web && pnpm --filter @genemap/desktop build:win",
    "build:desktop:mac": "pnpm build:web && pnpm --filter @genemap/desktop build:mac",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @genemap/api test",
    "test:shared": "pnpm --filter @genemap/shared test",
    "lint": "pnpm --filter @genemap/web lint && pnpm --filter @genemap/api lint",
    "lint:api": "pnpm --filter @genemap/api lint",
    "typecheck": "pnpm --filter @genemap/web typecheck && pnpm --filter @genemap/shared typecheck && pnpm --filter @genemap/api typecheck",
    "audit": "pnpm audit --prod --audit-level=high",
    "release:check": "pnpm install --frozen-lockfile && pnpm lint && pnpm typecheck && pnpm test && pnpm --filter @genemap/shared build && pnpm build:web && pnpm run audit",
    "db:generate": "pnpm --filter @genemap/api db:generate",
    "db:push": "pnpm --filter @genemap/api db:push",
    "db:migrate": "pnpm --filter @genemap/api db:migrate",
    "db:migrate:deploy": "pnpm --filter @genemap/api db:migrate:deploy",
    "db:studio": "pnpm --filter @genemap/api db:studio"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "minimatch": ">=3.1.4",
      "ajv@<6.14.0": "6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
      "qs": ">=6.14.2",
      "@tootallnate/once": ">=3.0.1",
      "rollup": ">=4.59.0",
      "effect@<3.20.0": ">=3.20.0",
      "picomatch": ">=4.0.4",
      "defu@<=6.1.4": ">=6.1.5",
      "postcss@<8.5.10": ">=8.5.10",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "fastify@>=5.3.2 <=5.8.4": ">=5.8.5",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "lodash@<=4.17.23": ">=4.18.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0"
  }
}
